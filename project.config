[access]
	inheritFrom = All-Projects
[submit]
	action = fast forward only
[access "refs/*"]
	owner = group user/Amarula (amarula-git)
	owner = group user/Michael Nazzareno Trimarchi (panicking)
[access "refs/for/refs/*"]
	label-Code-Review = -2..+2 group user/Amarula (amarula-git)
	label-Code-Review = -2..+2 group user/Michael Nazzareno Trimarchi (panicking)
	label-Verified = -1..+1 group user/Amarula (amarula-git)
	label-Verified = -1..+1 group user/Michael Nazzareno Trimarchi (panicking)
	push = group user/Amarula (amarula-git)
	push = group user/Michael Nazzareno Trimarchi (panicking)
	read = group user/Amarula (amarula-git)
	read = group user/Michael Nazzareno Trimarchi (panicking)
	rebase = group user/Michael Nazzareno Trimarchi (panicking)
	removeReviewer = group user/Amarula (amarula-git)
	removeReviewer = group user/Michael Nazzareno Trimarchi (panicking)
	submit = group user/Amarula (amarula-git)
	submit = group user/Michael Nazzareno Trimarchi (panicking)
[access "refs/heads/*"]
	create = group user/Amarula (amarula-git)
	create = group user/Michael Nazzareno Trimarchi (panicking)
	push = group user/Amarula (amarula-git)
	push = +force group user/Michael Nazzareno Trimarchi (panicking)
	pushMerge = group user/Amarula (amarula-git)
	pushMerge = group user/Michael Nazzareno Trimarchi (panicking)
	read = group user/Amarula (amarula-git)
	read = group user/Michael Nazzareno Trimarchi (panicking)
[access "refs/tags/*"]
	push = group user/Amarula (amarula-git)
	push = group user/Michael Nazzareno Trimarchi (panicking)
	push = +force group user/Michael Nazzareno Trimarchi (panicking)
